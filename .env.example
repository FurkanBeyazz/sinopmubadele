# ============================================================
#  Sinop Mübadele Derneği — Ortam Değişkenleri (ÖRNEK)
#  Bu dosyayı ".env" olarak kopyalayıp değerleri doldurun.
#  .env dosyasını ASLA git'e eklemeyin (zaten .gitignore'da).
# ============================================================

# --- Kimlik Doğrulama (NextAuth) ---
# Güçlü bir secret üretin:  openssl rand -base64 32
NEXTAUTH_SECRET=

# Production'da gerçek alan adınız (https ile):
NEXTAUTH_URL=https://alanadiniz.org

# --- Sitenin Genel Adresi (SEO / sitemap / OG) ---
NEXT_PUBLIC_SITE_URL=https://alanadiniz.org

# --- UploadThing (görsel yükleme) ---
# https://uploadthing.com panelinizden alın
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=
UPLOADTHING_TOKEN=

# --- (Opsiyonel) Google Analytics ---
# Ölçüm istemiyorsanız boş bırakın
NEXT_PUBLIC_GA_ID=
